# shellcheck disable=all

# Miner Gateway Environment Variables
# Copy this file to neurons/miner/gateway/.env and fill in your actual API keys

# Chutes AI API Key (Get your key from: https://chutes.ai/app)
CHUTES_API_KEY=your-chutes-api-key-here

# Desearch AI API Key (Get your key from: https://desearch.ai)
DESEARCH_API_KEY=your-desearch-api-key-here

# OpenAI API Key (Get your key from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Perplexity API Key (Get your key from: https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Vericore API Key (Get your key from: https://vericore.ai)
VERICORE_API_KEY=your-vericore-api-key-here

# OpenRouter API Key (Get your key from: https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Allowed models per provider (comma-separated, * = allow all)

# Chutes
ALLOWED_MODELS_CHUTES=deepseek-ai/DeepSeek-R1-0528,deepseek-ai/DeepSeek-R1,deepseek-ai/DeepSeek-V3-0324,deepseek-ai/DeepSeek-V3.1-Terminus,deepseek-ai/DeepSeek-V3.1,deepseek-ai/DeepSeek-TNG-R1T2-Chimera,deepseek-ai/DeepSeek-V3.2,deepseek-ai/DeepSeek-V3.2-Speciale,unsloth/gemma-3-4b-it,unsloth/gemma-3-12b-it,unsloth/gemma-3-27b-it,zai-org/GLM-4.6,zai-org/GLM-4.7,zai-org/GLM-4.7-Flash,zai-org/GLM-5-TEE,Qwen/Qwen2.5-VL-32B-Instruct,Qwen/Qwen3-32B,Qwen/Qwen3-235B-A22B,Qwen/Qwen3-235B-A22B-Instruct-2507,Qwen/Qwen3.5-397B-A17B-TEE,unsloth/Mistral-Small-24B-Instruct-2501,openai/gpt-oss-20b,openai/gpt-oss-120b,moonshotai/Kimi-K2.5-TEE,moonshotai/Kimi-K2-Thinking

# OpenAI
ALLOWED_MODELS_OPENAI=gpt-5.2,gpt-5.2-chat-latest,gpt-5.2-pro,gpt-5,gpt-5-mini,gpt-5-nano

# Perplexity
ALLOWED_MODELS_PERPLEXITY=sonar,sonar-pro,sonar-reasoning-pro

# OpenRouter
ALLOWED_MODELS_OPENROUTER=*

# Desearch models: NOVA ($0.004/call), ORBIT ($0.022/call), HORIZON ($0.026/call)
ALLOWED_MODELS_DESEARCH=NOVA

# Allowed endpoints per provider (comma-separated, * = allow all)

# Desearch: ai/search, ai/links, web/search, web/crawl, x/search, x/post
ALLOWED_ENDPOINTS_DESEARCH=ai/search,ai/links,web/search,web/crawl,x/search,x/post

# Vericore: calculate-rating ($0.05/call)
ALLOWED_ENDPOINTS_VERICORE=calculate-rating

# Rate limiting per IP (applied to /api/gateway/* endpoints only)
# Set both to 0 to disable rate limiting
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20

# IPs exempt from rate limiting (comma-separated)
RATE_LIMIT_EXEMPT_IPS=127.0.0.1
