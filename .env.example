# Numinous environment: "prod" or "test"
NUMINOUS_ENV=test

# API key for authenticating with the Numinous backend
NUMINOUS_API_KEY=your-api-key-here

# SQLite database path (default: ./crunch_node.db)
DATABASE_PATH=./crunch_node.db

# PostgreSQL connection DSN
PG_DSN=postgresql://user:password@localhost:5432/numinous

# Model Runner Client configuration
MRC_CRUNCH_ID=your-crunch-id
MRC_HOST=localhost
MRC_PORT=8765
MRC_BASE_CLASSNAME=your.module.ClassName
# MRC_SECURE_CREDENTIALS_DIR=/path/to/certs  # optional, directory with ca.crt, tls.crt, tls.key

# Gateway
RUN_REGISTRY_DIR=./deployment/gateway/run_registry/
GATEWAY_PORT=8090

# Task intervals (seconds)
PULL_EVENTS_INTERVAL=50.0
RESOLVE_EVENTS_INTERVAL=900.0
DELETE_EVENTS_INTERVAL=1800.0
RUN_MODELS_INTERVAL=600.0
REGISTER_MODELS_INTERVAL=300.0
SCORING_INTERVAL=307.0
EXPORT_SCORES_INTERVAL=373.0
EXPORT_PREDICTIONS_INTERVAL=180.0
EXPORT_AGENT_RUNS_INTERVAL=300.0
EXPORT_AGENT_RUN_LOGS_INTERVAL=600.0
DB_CLEANER_INTERVAL=53.0
DB_VACUUM_INTERVAL=300.0

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO