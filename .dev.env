# PostgreSQL configuration, do not change
POSTGRES_USER=numinous
POSTGRES_PASSWORD=numinous
POSTGRES_DB=numinous
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Numinous configuration
NUMINOUS_ENV=test
NUMINOUS_API_KEY=your-api-key-here

# Model Runner Client configuration, do not change
MRC_CRUNCH_ID=numinous
MRC_HOST=model-orchestrator
MRC_PORT=9091
MRC_BASE_CLASSNAME=numinous.tracker.TrackerBase

# During development, workers might be launched from the IDE
MODEL_ORCHESTRATOR_NETWORK=null

# OpenAI API Key to score the reasoning
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
